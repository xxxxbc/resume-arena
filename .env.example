# Admin password for /admin panel
ADMIN_PASSWORD=your-admin-password

# Secret salt for hashing admin cookie
ADMIN_TOKEN_SECRET=your-random-secret-string

# AI API configuration (OpenAI-compatible /v1/responses endpoint)
AI_API_URL=https://api.openai.com/v1/responses
AI_API_KEY=sk-your-api-key
AI_MODEL=gpt-4o

# Server port (default: 8080)
PORT=8080
